# =============================================
# Environment Variables – Army News VNAR
# =============================================
# SAO CHÉP file này thành .env và điền thông tin thực

# Server
PORT=3000
BASE_URL=http://localhost:3000

# Session secret (thay bằng chuỗi ngẫu nhiên dài, bí mật)
SESSION_SECRET=thay_bang_chuoi_bi_mat_cua_ban_o_day

# Database (đường dẫn đến file SQLite)
DB_PATH=./database.db

# SMTP – Gmail App Password
# Hướng dẫn: myaccount.google.com → Bảo mật → Mật khẩu ứng dụng
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password_here
SMTP_FROM="Army News VNAR <your_email@gmail.com>"

# Google reCAPTCHA v2 ("I'm not a robot")
# Hướng dẫn: https://www.google.com/recaptcha/admin/create
# Chọn loại: Challenge (v2) > "I'm not a robot" Checkbox
# Thêm localhost và domain thực vào Authorised domains
RECAPTCHA_SITE_KEY=your_site_key_here
RECAPTCHA_SECRET_KEY=your_secret_key_here
